SECRET_KEY=your-secret-key-here
DEBUG=True

# Base URL of the site — used to build absolute links in emails
SITE_URL=http://localhost:8000

# Email — leave EMAIL_BACKEND as console for local dev, switch to smtp for production
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend

# SendGrid — paste your API key here (Settings → API Keys → Create API Key → Full Access or Mail Send)
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxx

# The "From" address must be a verified sender in your SendGrid account
DEFAULT_FROM_EMAIL=noreply@strativvoice.com

# Slack incoming webhook URL (optional)
SLACK_WEBHOOK_URL=
